# File: usr/share/jellyfix/gui/windows/help_window.py, line: 113
#: usr/share/jellyfix/gui/windows/help_window.py:113
msgid "How to Use"
msgstr "Sådan bruger du"
# 
# File: usr/share/jellyfix/gui/windows/help_window.py, line: 113
#: usr/share/jellyfix/gui/windows/help_window.py:114
#, fuzzy
msgid ""
"<b>1. Configure TMDB API Key (recommended)</b>\n"
"   Menu → Configure API Keys → Follow the tutorial\n"
"   This enables metadata fetching and poster downloads.\n"
"\n"
"<b>2. Scan Library</b>\n"
"   Click \"Scan Library\" on Dashboard\n"
"   Select your media folder\n"
"   Review the scan results\n"
"\n"
"<b>3. Review Operations</b>\n"
"   Switch to \"Operations\" tab\n"
"   Preview what will be changed\n"
"   Select operations to see details\n"
"\n"
"<b>4. Execute</b>\n"
"   Click \"Process Files\"\n"
"   Confirm the operation\n"
"   Files will be renamed and organized\n"
"\n"
"<b>Tip:</b> Always review the preview before executing!"
msgstr ""
"<b>1. Konfigurer TMDB API-nøgle (anbefalet)</b>\n"
"   Menu → Konfigurer API-nøgler → Følg vejledningen\n"
"   Dette muliggør hentning af metadata og download af plakater.\n"
"\n"
"<b>2. Scann bibliotek</b>\n"
"   Klik på \"Scann bibliotek\" på instrumentbrættet\n"
"   Vælg din mediemappe\n"
"   Gennemgå scanningsresultaterne\n"
"\n"
"<b>3. Gennemgå operationer</b>\n"
"   Skift til fanen \"Operationer\"\n"
"   Forhåndsvis hvad der vil blive ændret\n"
"   Vælg operationer for at se detaljer\n"
"\n"
"<b>4. Udfør</b>\n"
"   Klik på \"Behandl filer\"\n"
"   Bekræft operationen\n"
"   Filerne vil blive omdøbt og organiseret\n"
"\n"
"<b>Tip:</b> Gennemgå altid forhåndsvisningen før udførelse!"
