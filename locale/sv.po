# File: usr/share/jellyfix/gui/windows/help_window.py, line: 113
#: usr/share/jellyfix/gui/windows/help_window.py:113
msgid "How to Use"
msgstr "Hur man använder"
# 
# File: usr/share/jellyfix/gui/windows/help_window.py, line: 113
#: usr/share/jellyfix/gui/windows/help_window.py:114
#, fuzzy
msgid ""
"<b>1. Configure TMDB API Key (recommended)</b>\n"
"   Menu → Configure API Keys → Follow the tutorial\n"
"   This enables metadata fetching and poster downloads.\n"
"\n"
"<b>2. Scan Library</b>\n"
"   Click \"Scan Library\" on Dashboard\n"
"   Select your media folder\n"
"   Review the scan results\n"
"\n"
"<b>3. Review Operations</b>\n"
"   Switch to \"Operations\" tab\n"
"   Preview what will be changed\n"
"   Select operations to see details\n"
"\n"
"<b>4. Execute</b>\n"
"   Click \"Process Files\"\n"
"   Confirm the operation\n"
"   Files will be renamed and organized\n"
"\n"
"<b>Tip:</b> Always review the preview before executing!"
msgstr ""
"<b>1. Konfigurera TMDB API-nyckel (rekommenderas)</b>\n"
"   Meny → Konfigurera API-nycklar → Följ guiden\n"
"   Detta möjliggör hämtning av metadata och nedladdning av affischer.\n"
"\n"
"<b>2. Skanna bibliotek</b>\n"
"   Klicka på \"Skanna bibliotek\" på instrumentpanelen\n"
"   Välj din mediamapp\n"
"   Granska skanningsresultaten\n"
"\n"
"<b>3. Granska operationer</b>\n"
"   Väx till fliken \"Operationer\"\n"
"   Förhandsgranska vad som kommer att ändras\n"
"   Välj operationer för att se detaljer\n"
"\n"
"<b>4. Utför</b>\n"
"   Klicka på \"Bearbeta filer\"\n"
"   Bekräfta operationen\n"
"   Filer kommer att döpas om och organiseras\n"
"\n"
"<b>Tips:</b> Granska alltid förhandsgranskningen innan du utför!"
