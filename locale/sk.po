# File: usr/share/jellyfix/gui/windows/help_window.py, line: 104
#: NEEDS WORK
msgid ""
"<b>Movies:</b>\n"
"  Before: movie.name.2023.1080p.bluray.mkv\n"
"  After:  Movie Name (2023) [tmdbid-12345]/Movie Name (2023) - 1080p.mkv\n"
"\n"
"<b>TV Shows:</b>\n"
"  Before: show.name.s01e05.720p.mkv\n"
"  After:  Show Name (2024) [tmdbid-67890]/Season 01/Show Name - S01E05 - 720p.mkv\n"
"\n"
"<b>Subtitles:</b>\n"
"  • Renames: .por2.srt → .por.srt, .eng3.srt → .eng.srt\n"
"  • Adds language codes: subtitle.srt → Movie Name.por.srt\n"
"  • Removes foreign languages (keeps configured languages only)\n"
"  • <b>NEVER</b> removes .forced.srt files"
msgstr ""
"<b>Filmy:</b>\n"
"  Pred: movie.name.2023.1080p.bluray.mkv\n"
"  Po:  Názov Filmu (2023) [tmdbid-12345]/Názov Filmu (2023) - 1080p.mkv\n"
"\n"
"<b>Televízne relácie:</b>\n"
"  Pred: show.name.s01e05.720p.mkv\n"
"  Po:  Názov Relácie (2024) [tmdbid-67890]/Sezóna 01/Názov Relácie - S01E05 - 720p.mkv\n"
"\n"
"<b>Titulky:</b>\n"
"  • Premenováva: .por2.srt → .por.srt, .eng3.srt → .eng.srt\n"
"  • Pridáva jazykové kódy: subtitle.srt → Názov Filmu.por.srt\n"
"  • Odstraňuje cudzí jazyk (uchováva iba nakonfigurované jazyky)\n"
"  • <b>NIKDY</b> neodstraňuje .forced.srt súbory"
