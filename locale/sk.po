msgstr "Ako používať"
# 
# File: usr/share/jellyfix/gui/windows/help_window.py, line: 113
#: usr/share/jellyfix/gui/windows/help_window.py:114
#, fuzzy
msgid ""
"<b>1. Configure TMDB API Key (recommended)</b>\n"
"   Menu → Configure API Keys → Follow the tutorial\n"
"   This enables metadata fetching and poster downloads.\n"
"\n"
"<b>2. Scan Library</b>\n"
"   Click \"Scan Library\" on Dashboard\n"
"   Select your media folder\n"
"   Review the scan results\n"
"\n"
"<b>3. Review Operations</b>\n"
"   Switch to \"Operations\" tab\n"
"   Preview what will be changed\n"
"   Select operations to see details\n"
"\n"
"<b>4. Execute</b>\n"
"   Click \"Process Files\"\n"
"   Confirm the operation\n"
"   Files will be renamed and organized\n"
"\n"
"<b>Tip:</b> Always review the preview before executing!"
msgstr ""
"<b>1. Konfigurujte TMDB API kľúč (odporúčané)</b>\n"
"   Menu → Konfigurujte API kľúče → Postupujte podľa tutoriálu\n"
"   Toto umožňuje načítanie metadát a sťahovanie plagátov.\n"
"\n"
"<b>2. Prehľadať knižnicu</b>\n"
"   Kliknite na \"Prehľadať knižnicu\" na paneli\n"
"   Vyberte svoju mediálnu zložku\n"
"   Skontrolujte výsledky skenovania\n"
"\n"
"<b>3. Skontrolovať operácie</b>\n"
"   Prepnite na kartu \"Operácie\"\n"
"   Náhľad toho, čo sa zmení\n"
"   Vyberte operácie na zobrazenie podrobností\n"
"\n"
"<b>4. Spustiť</b>\n"
"   Kliknite na \"Spracovať súbory\"\n"
"   Potvrďte operáciu\n"
"   Súbory budú premenované a usporiadané\n"
"\n"
"<b>Tip:</b> Vždy skontrolujte náhľad pred spustením!"
